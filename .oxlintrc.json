{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["unicorn", "oxc"],
  "categories": {
    "correctness": "error",
    "nursery": "error",
    "suspicious": "warn",
    "pedantic": "off"
  },
  "rules": {
    "eslint/no-unused-vars": "error"
  },
  "env": {
    "builtin": true
  }
}
