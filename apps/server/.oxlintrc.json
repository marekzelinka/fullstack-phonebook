{
  "extends": ["../../.oxlintrc.json"],
  "plugins": ["node"],
  "env": {
    "node": true
  },
  "rules": {
    "unicorn/no-process-exit": "warn",
    "unicorn/prefer-module": "error",
    "no-console": "off",
    "no-async-endpoint-handlers": "off",
    "eslint/no-underscore-dangle": "off"
  }
}
